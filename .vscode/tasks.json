{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "bettbox: ensure windows dev core",
      "type": "shell",
      "command": "dart",
      "args": [
        "./setup.dart",
        "windows",
        "--arch",
        "auto",
        "--out",
        "core",
        "--dev",
        "--ensure"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build"
    },
