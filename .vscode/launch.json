{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Bettbox Windows Dev",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "program": "lib/main.dart",
      "deviceId": "windows",
      "toolArgs": [
        "--dart-define",
        "APP_FLAVOR=dev"
      ],
      "preLaunchTask": "bettbox: ensure windows dev core"
    },
